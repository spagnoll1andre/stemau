<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit stock.picking form view — add Stemau tab -->
    <record id="stock_picking_form_stemau" model="ir.ui.view">
        <field name="name">stock.picking.form.stemau</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Stemau" name="stemau_tab">
                    <group string="Shipment Info">
                        <field name="x_carrier_ref"/>
                        <field name="x_loading_notes"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
